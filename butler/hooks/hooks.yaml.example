# Copy to ~/.butler/config.yaml under `hooks:` or to <project>/.butler/hooks.yaml
# Claude Code–compatible shell hooks (stdin JSON). See CONTRIBUTING.md § Butler 线束.
#
# Process-internal hooks (pre_llm_call, pre_gateway_dispatch) live in butler/gateway/hooks.py.

hooks:
  PreToolUse:
    - matcher: "write_file|patch"
      command: "echo 'blocked by example hook' >&2; exit 2"
  PostToolUse:
    - matcher: read_file
      command: "echo 'read ok'"
  UserPromptSubmit:
    - matcher: "*"
      command: "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":[\"[hook] git status stub\"]}}'"
  PermissionDenied:
    - matcher: write_file
      command: "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionDenied\",\"retry\":true}}'"
  SessionStart:
    - matcher: "*"
      command: "echo 'session started'"
  SessionEnd:
    - matcher: clear
      command: "echo 'session cleared'"
  Stop:
    - matcher: completed
      command: "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"Stop\",\"additionalContext\":[\"[hook] turn metrics stub\"]}}'"
  SubagentStart:
    - matcher: dev
      command: "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SubagentStart\",\"additionalContext\":[\"[hook] delegate audit stub\"]}}'"
