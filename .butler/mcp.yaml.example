# Copy to ~/.butler/mcp.yaml or <project>/.butler/mcp.yaml
# Requires: pip install butler-system[mcp] and BUTLER_MCP_ENABLED=1

version: 1
servers:
  # example_stdio:
  #   transport: stdio
  #   command: python3
  #   args: ["/path/to/your_mcp_server.py"]
  #   timeout_seconds: 60
  #   tools:
  #     allow: ["tool_a", "tool_b"]
  #   classify:
  #     tool_a: readonly

  # example_http:
  #   transport: http
  #   url: https://mcp.example.com/mcp
  #   sse: false
  #   headers:
  #     Authorization: "Bearer ${MCP_CORP_TOKEN}"
  #   hosts_allow: ["mcp.example.com"]

  # EXT-1: Firecrawl web scrape/crawl (see docs/plans/active/extension-candidates/ext-1-web-scrape-mcp-2026-06.md)
  # Requires: Node 18+, npx in BUTLER_MCP_STDIO_ALLOW_COMMANDS, FIRECRAWL_API_KEY in secrets or env
  # firecrawl:
  #   transport: stdio
  #   command: npx
  #   args: ["-y", "firecrawl-mcp"]
  #   timeout_seconds: 120
  #   env:
  #     FIRECRAWL_API_KEY: "${FIRECRAWL_API_KEY}"
  #   tools:
  #     allow: []   # empty = all tools from server after probe
  #   classify:
  #     firecrawl_scrape: readonly
  #     firecrawl_crawl: readonly
  #     firecrawl_map: readonly

  # EXT-2: Todoist REST v2 read-only (see docs/plans/active/extension-candidates/ext-2-openapi-http-2026-06.md)
  # Requires: Node 18+, npx in BUTLER_MCP_STDIO_ALLOW_COMMANDS, TODOIST_API_TOKEN in secrets or env
  # Pin spec: curl -o ~/.butler/openapi/todoist-rest-v2.yml <raw url in ext-2 doc>
  # todoist:
  #   transport: stdio
  #   command: npx
  #   args:
  #     - "-y"
  #     - "@ivotoby/openapi-mcp-server"
  #     - "--api-base-url"
  #     - "https://api.todoist.com/rest/v2"
  #     - "--openapi-spec"
  #     - "${HOME}/.butler/openapi/todoist-rest-v2.yml"
  #   timeout_seconds: 90
  #   env:
  #     API_HEADERS: "Authorization:Bearer ${TODOIST_API_TOKEN}"
  #   tools:
  #     allow:
  #       - getAllProjects
  #       - getActiveTasks
  #   classify:
  #     getAllProjects: readonly
  #     getActiveTasks: readonly

  # EXT-4: GitHub REST read-only (ext-4-second-openapi-2026-06.md)
  # bash scripts/butler-github-openapi-spec-install.sh && bash scripts/butler-extension-ext4-integrate.sh
  # github: … see ext-4 doc §4

  # EXT-5: MarkItDown document convert (ext-5-markitdown-mcp-2026-06.md)
  # bash scripts/butler-extension-ext5-integrate.sh
  # Requires: uvx in BUTLER_MCP_STDIO_ALLOW_COMMANDS, markitdown-mcp via uvx/pip
  # markitdown:
  #   transport: stdio
  #   command: uvx
  #   args: ["markitdown-mcp"]
  #   timeout_seconds: 120
