# 项目 workspace 内放置为 .butler/permissions.yaml（CC permissions 子集，无 LLM classifier）
#
# 复制：cp docs/templates/permissions.yaml.example projects/<YourProject>/.butler/permissions.yaml

# 单工具策略（阶段 C6）：按工具名直接 allow / ask / deny（优先于 rules 路径匹配）
# tool_policies:
#   write_file: ask
#   patch: ask
#   terminal: deny

# rules 按列表顺序匹配，**最后一条匹配的规则生效**（OpenCode last-match）
rules:
  - tool: terminal
    action: deny
    reason: 微信/Lead 场景禁止 shell

  - tool: write_file
    path: ".env*"
    action: deny
    reason: 禁止通过 Agent 写环境密钥文件

  # - tool: read_file
  #   path: "secrets/*"
  #   action: ask
  #   reason: 敏感路径需 Owner 确认（/批准一次 或 /始终允许 rule）

# 工作区外路径（OpenCode external_directory 子集）
# external_directory:
#   - path: "/tmp/**"
#     action: ask
#     reason: 访问 /tmp 需 Owner 批准
#   - path: "/home/**"
#     action: deny
#     reason: 禁止读取用户主目录

# 工作流 DAG 步骤级工具白名单（P2）：仅当 TaskOrchestrator 执行该 step_id 时生效
workflow_steps:
  dev_write:
    tools:
      - read_file
      - write_file
      - patch
      - search_files
  review:
    tools:
      - read_file
      - search_files

# 工作流步骤人工确认：在 workflow YAML 中为 step 设置 requires_approval: true
# 微信回复「确认」后再次 /workflow <name> 继续

# 委派子代理工具集（OpenCode deriveSubagent 子集）
# delegate_subagent:
#   deny_tools: [run_runtime_job]
#   allow_tools: [read_file, search_files, patch]   # 若设置则仅允许列表内工具
#   roles:
#     review:
#       allow_tools: [read_file, search_files]
