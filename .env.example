# BUTLER_NOTIFY_URLS — 未接入 butler/ 运行时（apprise 规划项）
# --- [analytics] duckdb 本地数据查询（CSV/JSON/Parquet/SQLite）---
# BUTLER_DATA_QUERY=1                     # 默认开启（安装 duckdb 后）

