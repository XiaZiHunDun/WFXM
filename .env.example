# Butler System 环境变量配置

# === 必填: 至少配置一个 LLM Provider ===

# Anthropic Claude (推荐作为默认)
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

# DeepSeek（可选；未配置时全栈默认仍走 MiniMax）
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat

# 默认 Provider（管家主对话、auxiliary 侧任务、无 step model 的工作流）
# BUTLER 代码默认 default_provider=minimax；也可在 ~/.butler/config.yaml 写 default_provider

# 通义千问 (Qwen)
# DASHSCOPE_API_KEY=sk-xxx

# 智谱 GLM
# ZHIPUAI_API_KEY=xxx

# Moonshot (Kimi)
# MOONSHOT_API_KEY=sk-xxx

# === Butler 原生微信网关（iLink Bot API）===
# WECHAT_TOKEN=
# WECHAT_ACCOUNT_ID=
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# 绑定: butler wechat-setup
# 常驻: bash scripts/install-butler-gateway-service.sh
#
# --- 生产网关强烈建议（P0）---
# WECHAT_DM_POLICY=allowlist
# WECHAT_ALLOWED_USERS=<你的微信 user id，逗号分隔>
# BUTLER_OWNER_WECHAT_ID=<Owner 微信 chat_id；runtime 推送目标，默认同 WECHAT_ALLOWED_USERS 首项>
# BUTLER_PROJECT_CREATE_OPEN=0        # 1=开发环境跳过 Owner 校验（/项目 新建）
# BUTLER_RUNTIME_ENABLED=1          # 0=禁用 runtime；Agent list_runtime_jobs / run_runtime_job 亦不可用
# BUTLER_RUNTIME_PUSH=1             # 0=任务结果不推微信
# BUTLER_RUNTIME_SMOKE_PUSH=0       # 1=butler-runtime-smoke.sh 允许推送（默认 0）
# BUTLER_RUNTIME_FAIL_ALERT_STREAK=3  # 同一任务连续失败 N 次后微信告警（不自动重试）
# BUTLER_RUNTIME_PUSH_COOLDOWN_SECONDS=25  # 连续 runtime 推送最小间隔，减轻 iLink 限流
# BUTLER_RUNTIME_PUSH_QUEUE=1           # 限流失败入队，runtime due 时 drain 重试
# WECHAT_SEND_CHUNK_RETRIES=6
# WECHAT_SEND_CHUNK_RETRY_DELAY_SECONDS=2
# BUTLER_DEFAULT_PROJECT=灵文1号
# BUTLER_TOOL_SAFE_ROOT=/home/you/projects/WFXM/projects
# BUTLER_GATEWAY_HANDLER_TIMEOUT=600
# BUTLER_GATEWAY_HANDLER_WORKERS=2
# BUTLER_GATEWAY_TYPING_ENABLED=1
# BUTLER_GATEWAY_PROGRESS_ACK_ENABLED=1
# BUTLER_GATEWAY_PROGRESS_ACK_SECONDS=30
# --- 长任务完成额外微信推送（出站层，非 shell hook）---
# BUTLER_GATEWAY_COMPLETION_NOTIFY=1
# BUTLER_GATEWAY_COMPLETION_NOTIFY_MIN_SECONDS=90
# BUTLER_GATEWAY_DELEGATE_COMPLETION_NOTIFY=1
# BUTLER_GATEWAY_DELEGATE_COMPLETION_MODE=last   # last | each | once
# BUTLER_GATEWAY_DELEGATE_COMPLETION_MAX_EACH=3
# BUTLER_GATEWAY_TURN_COMPLETION_NOTIFY=1
# BUTLER_GATEWAY_WORKFLOW_COMPLETION_NOTIFY=1
# BUTLER_GATEWAY_TIMEOUT_COMPLETION_NOTIFY=1
# 与 runtime 推送共用冷却与失败入队：
# BUTLER_RUNTIME_PUSH_COOLDOWN_SECONDS=25
# BUTLER_RUNTIME_PUSH_QUEUE=1
# --- 大工具结果落盘（上下文指针，非截断丢弃）---
# BUTLER_TOOL_RESULT_SPILL=1
# BUTLER_TOOL_RESULT_SPILL_MIN_CHARS=8192
# BUTLER_TOOL_RESULT_SPILL_PREVIEW_CHARS=2000
# BUTLER_TOOL_RESULT_THRESHOLDS={"grep":4096,"terminal":12000}
# BUTLER_TOOL_RESULT_MESSAGE_BUDGET=1
# BUTLER_TOOL_RESULT_MESSAGE_MAX_CHARS=200000
# BUTLER_SESSION_TRANSCRIPT=1
# BUTLER_SESSION_TRANSCRIPT_MAX_BYTES=52428800
# BUTLER_READ_STATE_MAX_ENTRIES=100
# --- 工具输出分级剪枝（micro，LLM 压缩前）---
# BUTLER_TOOL_PRUNE_KEEP_RECENT=4
# BUTLER_TOOL_PRUNE_CLEARABLE_CHARS=400
# BUTLER_TOOL_PRUNE_PRESERVE_CHARS=2400
# BUTLER_TOOL_PRUNE_DEFAULT_CHARS=800
# OpenCode-style backward tool-output prune (before LLM compress)
# BUTLER_TOOL_PRUNE_BACKWARD=1
# BUTLER_TOOL_PRUNE_BACKWARD_MINIMUM=20000
# BUTLER_TOOL_PRUNE_BACKWARD_PROTECT=40000
# BUTLER_COMPACTION_USE_OPENCODE_TEMPLATE=1
# BUTLER_DOOM_LOOP_THRESHOLD=3
# BUTLER_INSTRUCTION_WALKUP=1
# BUTLER_INSTRUCTION_WALKUP_MAX_CHARS=4000
# P2: session todos replace-all (~/.butler/sessions/<key>/todos.json)
# BUTLER_SESSION_TODOS=1
# BUTLER_SESSION_TODOS_MAX_ITEMS=30
# --- P3：可选 MCP 薄客户端（pip install butler-system[mcp]）---
# BUTLER_MCP_ENABLED=0
# BUTLER_MCP_CONFIG=~/.butler/mcp.yaml
# BUTLER_MCP_MAX_SERVERS=3
# BUTLER_MCP_MAX_TOOLS=20
# BUTLER_MCP_TOOL_PREFIX=mcp
# BUTLER_MCP_STDIO_ALLOW_COMMANDS=python,python3,uvx
# BUTLER_MCP_HTTP_HOSTS_ALLOW=
# BUTLER_MCP_SESSION_SCOPED=1
# BUTLER_MCP_HTTP_ALLOW_PRIVATE=0
# --- 读后再改（patch/write 前须 read_file + mtime 一致）---
# BUTLER_READ_BEFORE_EDIT=1
# --- P1：入站队列 / Stop 阻断 / 本轮 token 预算 ---
# BUTLER_GATEWAY_MESSAGE_QUEUE=1
# BUTLER_GATEWAY_QUEUE_MODE=followup          # followup | collect | interrupt | steer
# BUTLER_GATEWAY_QUEUE_CAP=20
# BUTLER_GATEWAY_QUEUE_DROP=summarize         # summarize | old | new
# BUTLER_GATEWAY_QUEUE_COLLECT_DEBOUNCE_MS=500
# BUTLER_GATEWAY_QUEUE_DRAIN_PER_TURN=1
# BUTLER_GATEWAY_QUEUE_PUSH_VIA_BRIDGE=1   # drain 的排队消息单独出站，不拼进主回复
# BUTLER_TURN_TOKEN_BUDGET=1
# --- P2：流式只读预取 / cache-safe 委派 ---
# BUTLER_STREAMING_TOOLS=1                 # 流式只读工具参数完整后立即预执行
# BUTLER_CACHE_SAFE_DELEGATE=1             # delegate_task 子 loop 共享父 system 前缀
# BUTLER_CACHE_SAFE_SHARED_CHARS=4096
# BUTLER_CACHE_SAFE_MESSAGES_CHARS=2048
# BUTLER_TURN_BUDGET_DEFAULT=500000
# BUTLER_TURN_BUDGET_MAX_ITERATIONS=60
# BUTLER_TURN_BUDGET_MAX_CONTINUATIONS=3
# BUTLER_TURN_BUDGET_MIN_DELTA=500
# BUTLER_SYNC_CONVERSATION_MEMORY=0   # 0=不把每轮聊天写入 experience；1=恢复旧行为
# BUTLER_EXPERIENCE_PRUNE_DAYS=30     # 清理超过 N 天的 conversation 回声；0=关闭
# BUTLER_PREFETCH_MAX_CHARS=3000      # 单轮 user 消息外包记忆块上限
# BUTLER_PREFETCH_TOTAL_MAX_CHARS=3500
# BUTLER_PREFETCH_PROJECT_MAX_CHARS=1200
# BUTLER_PREFETCH_FACTS_MAX_CHARS=400
# BUTLER_PREFETCH_EXPERIENCE_HITS=5
# BUTLER_PREFETCH_PROJECT_HITS=5    # 有 query 时项目 MEMORY 向量预取条数
# BUTLER_QUEUE_PREFETCH=1           # 试点推荐 1：上轮结束后 warm（下轮同句可命中缓存）
# BUTLER_PREFETCH_CACHE_TTL=90
# BUTLER_SEMANTIC_MEMORY=1          # 试点推荐 1：本地向量+混合检索（默认 hashing，无需外网）
# BUTLER_EMBEDDING_PROVIDER=local   # local | openai | minimax（API 需对应 *_API_KEY，失败回退 hashing）
# BUTLER_EMBEDDING_MODEL=hashing-v1 # openai 默认 text-embedding-3-small；minimax 默认 embo-01
# BUTLER_VECTOR_HYBRID_WEIGHT=0.5
# BUTLER_FTS_HYBRID_WEIGHT=          # 可选，默认 1 - VECTOR_HYBRID_WEIGHT
# BUTLER_SEMANTIC_SEARCH_LIMIT=8
# BUTLER_MEMORY_HALF_LIFE_DAYS=30   # 检索衰减半衰期（天），越久记忆权重越低
# BUTLER_MEMORY_ACCESS_BOOST=0.12   # 访问次数对排序的 log 加权系数
# === 开发操作工具（详见 docs/architecture/dev-ops-tools-design.md） ===
# BUTLER_ENABLE_TERMINAL=1
# BUTLER_TERMINAL_PROFILE=pilot          # 空 | pilot（python3,bash）| dev（+pytest,git,pip,npm…）
# BUTLER_TERMINAL_ALLOWLIST_EXTRA=python3,bash   # 在 profile 之上追加
# BUTLER_ENABLE_GIT=1                    # git_status / git_diff / git_log / git_branch list
# BUTLER_ENABLE_GIT_WRITE=0              # 1=git_add / git_commit / branch 变更（仅建议本机）
# BUTLER_TOOL_AUDIT_JSONL=0              # 1=工具调用追加写入 ~/.butler/audit/tools.jsonl
# BUTLER_TOOL_AUDIT_PATH=               # 可选自定义 JSONL 路径
# BUTLER_ENABLE_DOWNLOAD=0               # 1=download_file（HTTPS + 域名白名单）
# BUTLER_DOWNLOAD_ALLOW_HOSTS=github.com,raw.githubusercontent.com,files.pythonhosted.org
# BUTLER_DOWNLOAD_MAX_BYTES=10485760

# === 真实 API Smoke（本地手动，默认 pytest 不运行） ===
# BUTLER_RUN_REAL_API_SMOKE=1
# BUTLER_SMOKE_DEEPSEEK_MODEL=deepseek-chat
# BUTLER_SMOKE_DEEPSEEK_REASONER_MODEL=deepseek-reasoner
# BUTLER_SMOKE_MINIMAX_MODEL=MiniMax-M2.7
# BUTLER_SMOKE_QWEN_MODEL=qwen-max
# 运行: pytest -m live_llm tests/test_real_api_smoke.py

# === 管家配置 ===

# BUTLER_HOME=~/.butler
# BUTLER_PROJECTS_DIR=./projects

# === 工具安全边界 ===
# 默认工具访问范围为当前项目 workspace；未选择项目时回退到 BUTLER_TOOL_SAFE_ROOT 或进程 cwd。
# 建议生产网关显式设置安全根目录。
# BUTLER_TOOL_SAFE_ROOT=/path/to/workspace
#
# terminal 工具默认关闭。仅在明确接受本机命令执行风险时启用；
# 启用后仍使用受限 argv + allowlist 模式，不支持 shell 管道/重定向/变量展开。
# read_file 限制单文件 1MiB / 单次 1000 行；terminal 限制单次 120 秒 / 50000 字符输出。
# write_file / patch 使用同目录临时文件原子替换，并拒绝 symlink / hardlink / 非普通文件目标。
# 工具错误、guardrail block/halt、dispatcher 兜底会追加 ok/tool/code 兼容 envelope，
# 并在内存中保留脱敏审计事件供 /health 汇总。
# guardrail halt 使用 TOOL_GUARDRAIL_HALT，block 使用 TOOL_GUARDRAIL_BLOCKED。
# 自定义 dispatcher 若手写完整 envelope，应直接复用 finalize_tool_result 以写入审计。
# BUTLER_ENABLE_TERMINAL=0

# === Gateway 会话生命周期 ===
# 按 session_key 缓存 AgentLoop；超过空闲 TTL 或 LRU 上限时会触发 session finalize。
# BUTLER_GATEWAY_SESSION_IDLE_TTL_SECONDS=3600
# BUTLER_GATEWAY_MAX_SESSIONS=128
# Session reset/evict/LRU also clears in-memory tool audit events for that session_key.

# === WeChat 配置 (Phase 3) ===

# 入站图片/语音理解（网关层，不走厂长主模型）
# BUTLER_WECHAT_INBOUND_MEDIA=1
# BUTLER_WECHAT_MEDIA_MAX_CHARS=3000
# 识图：MiniMax Coding Plan VLM（需 MINIMAX_API_KEY；国际区默认 https://api.minimax.io）
# BUTLER_WECHAT_MINIMAX_API_HOST=https://api.minimax.io
# BUTLER_WECHAT_VISION_TIMEOUT=45
# 语音：prefer_ilink_text=true 时有 iLink 转写则跳过本地 STT（config.yaml gateway.inbound_media.speech）
# BUTLER_WECHAT_PREFER_ILINK_TEXT=1
# BUTLER_WECHAT_STT_PROVIDER=local
# BUTLER_WECHAT_WHISPER_MODEL=small
# BUTLER_WECHAT_STT_PROVIDER=off
# 识图失败回退（逗号分隔）：openai 需 OPENAI_API_KEY；ocr 需 pytesseract+pillow
# BUTLER_WECHAT_VISION_FALLBACK=openai,ocr
# 微信 /开发验收（跑 test_dev_tools_integration；生产建议 0）
# BUTLER_WECHAT_DEV_SMOKE=0

# （已移除 Wechaty/WECHATY_PUPPET* — Butler v4 仅 iLink 微信网关）
