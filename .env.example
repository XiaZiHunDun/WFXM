# Butler System 环境变量配置

# === 必填: 至少配置一个 LLM Provider ===

# Anthropic Claude (推荐作为默认)
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat

# 通义千问 (Qwen)
# DASHSCOPE_API_KEY=sk-xxx

# 智谱 GLM
# ZHIPUAI_API_KEY=xxx

# Moonshot (Kimi)
# MOONSHOT_API_KEY=sk-xxx

# === Butler 原生微信网关（iLink Bot API）===
# WECHAT_TOKEN=
# WECHAT_ACCOUNT_ID=
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# 绑定: butler wechat-setup
# 常驻: bash scripts/install-butler-gateway-service.sh
#
# --- 生产网关强烈建议（P0）---
# WECHAT_DM_POLICY=allowlist
# WECHAT_ALLOWED_USERS=<你的微信 user id，逗号分隔>
# BUTLER_DEFAULT_PROJECT=<project.yaml 中的 name，避免无项目时工具不受限>
# BUTLER_TOOL_SAFE_ROOT=/home/you/projects/WFXM/projects
# BUTLER_GATEWAY_HANDLER_TIMEOUT=300

# === 真实 API Smoke（本地手动，默认 pytest 不运行） ===
# BUTLER_RUN_REAL_API_SMOKE=1
# BUTLER_SMOKE_DEEPSEEK_MODEL=deepseek-chat
# BUTLER_SMOKE_DEEPSEEK_REASONER_MODEL=deepseek-reasoner
# BUTLER_SMOKE_MINIMAX_MODEL=MiniMax-M2.7
# BUTLER_SMOKE_QWEN_MODEL=qwen-max
# 运行: pytest -m live_llm tests/test_real_api_smoke.py

# === 管家配置 ===

# BUTLER_HOME=~/.butler
# BUTLER_PROJECTS_DIR=./projects

# === 工具安全边界 ===
# 默认工具访问范围为当前项目 workspace；未选择项目时回退到 BUTLER_TOOL_SAFE_ROOT 或进程 cwd。
# 建议生产网关显式设置安全根目录。
# BUTLER_TOOL_SAFE_ROOT=/path/to/workspace
#
# terminal 工具默认关闭。仅在明确接受本机命令执行风险时启用；
# 启用后仍使用受限 argv + allowlist 模式，不支持 shell 管道/重定向/变量展开。
# read_file 限制单文件 1MiB / 单次 1000 行；terminal 限制单次 120 秒 / 50000 字符输出。
# write_file / patch 使用同目录临时文件原子替换，并拒绝 symlink / hardlink / 非普通文件目标。
# 工具错误、guardrail block/halt、dispatcher 兜底会追加 ok/tool/code 兼容 envelope，
# 并在内存中保留脱敏审计事件供 /health 汇总。
# guardrail halt 使用 TOOL_GUARDRAIL_HALT，block 使用 TOOL_GUARDRAIL_BLOCKED。
# 自定义 dispatcher 若手写完整 envelope，应直接复用 finalize_tool_result 以写入审计。
# BUTLER_ENABLE_TERMINAL=0

# === Gateway 会话生命周期 ===
# 按 session_key 缓存 AgentLoop；超过空闲 TTL 或 LRU 上限时会触发 session finalize。
# BUTLER_GATEWAY_SESSION_IDLE_TTL_SECONDS=3600
# BUTLER_GATEWAY_MAX_SESSIONS=128
# Session reset/evict/LRU also clears in-memory tool audit events for that session_key.

# === WeChat 配置 (Phase 3) ===

# Wechaty
# WECHATY_PUPPET=wechaty-puppet-service
# WECHATY_PUPPET_SERVICE_TOKEN=xxx
