# Butler System 环境变量配置

# === 日志 ===
# BUTLER_LOG_LEVEL=INFO      # DEBUG / INFO / WARNING / ERROR

# === 必填: 至少配置一个 LLM Provider ===

# Anthropic Claude (推荐作为默认)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# DeepSeek（可选；未配置时全栈默认仍走 MiniMax）
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_MODEL=deepseek-chat

# 默认 Provider（管家主对话、auxiliary 侧任务、无 step model 的工作流）
# BUTLER 代码默认 default_provider=minimax；也可在 ~/.butler/config.yaml 写 default_provider

# 通义千问 (Qwen)
# DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 智谱 GLM
# ZHIPUAI_API_KEY=xxx

# Moonshot (Kimi)
# MOONSHOT_API_KEY=your-moonshot-api-key-here

# === Butler 原生微信网关（iLink Bot API）===
# WECHAT_TOKEN=
# WECHAT_ACCOUNT_ID=
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# 绑定: butler wechat-setup
# 常驻: bash scripts/install-butler-gateway-service.sh
#
# --- 生产网关强烈建议（P0）---
# WECHAT_DM_POLICY=allowlist
# WECHAT_ALLOWED_USERS=<你的微信 user id，逗号分隔>
# BUTLER_OWNER_WECHAT_ID=<Owner 微信 chat_id；runtime 推送、/批准执行、doctor 通过>
# BUTLER_GATEWAY_ALLOWLIST=<历史兼容 fallback allowlist；仅在未设 Owner/WECHAT_ALLOWED_USERS 时，runtime push 与 Owner gate 会读取；DM 入站仍看 WECHAT_ALLOWED_USERS>
# BUTLER_PROJECT_CREATE_OPEN=0        # 1=开发环境跳过 Owner 校验（/项目 新建）
# BUTLER_RUNTIME_ENABLED=1          # 0=禁用 runtime；Agent list_runtime_jobs / run_runtime_job 亦不可用
# BUTLER_RUNTIME_PUSH=1             # 0=任务结果不推微信
# BUTLER_RUNTIME_SMOKE_PUSH=0       # 1=butler-runtime-smoke.sh 允许推送（默认 0）
# BUTLER_RUNTIME_FAIL_ALERT_STREAK=3  # 同一任务连续失败 N 次后微信告警（不自动重试）
# BUTLER_RUNTIME_PUSH_COOLDOWN_SECONDS=25  # 连续 runtime 推送最小间隔，减轻 iLink 限流
# BUTLER_RUNTIME_PUSH_DRAIN_COOLDOWN_SECONDS=300  # 限流后跳过 drain-push，避免反复 hammer iLink
# BUTLER_RUNTIME_PUSH_QUEUE=1           # 限流失败入队，runtime due 时 drain 重试
# WECHAT_SEND_CHUNK_RETRIES=6
# WECHAT_SEND_CHUNK_RETRY_DELAY_SECONDS=2
# BUTLER_DEFAULT_PROJECT=灵文1号
# BUTLER_TOOL_SAFE_ROOT=/home/you/projects/WFXM/projects
