# === Sprint 1-5 新增 (2026-05) ===
# BUTLER_CONFIRM_WRITE_OPS=1            # 写操作二次确认（默认启用）
# BUTLER_OBSERVATION_TTL_DAYS=90        # Observation Store TTL 天数（默认90）
# BUTLER_ONBOARDING_WELCOME=1           # 首次会话 Welcome 消息（默认启用，0 禁用）

# === Sprint 6+ 增量开关（审计 5.1.10 同步；缺省值见 reference.md） ===
# --- 目录与多租户 ---
# BUTLER_RUNTIME_DIRS=                  # 逗号分隔，runtime 写入白名单目录（默认见 config.py）
# --- 工具层：retry / pair repair / selector / masking / tool names ---
# BUTLER_TOOL_RETRY_MAX=2               # 单 tool 失败重试上限
# BUTLER_TOOL_RETRY_BACKOFF_SECONDS=0.4 # 重试退避基数
# BUTLER_TOOL_PAIR_REPAIR=1             # 1=配对工具（read_file/write_file）错误时尝试修复
# BUTLER_TOOL_SELECTOR_THRESHOLD=12     # 工具数超过此值才启用 LLM 选择器
# BUTLER_TOOL_CALL_LIMIT_EXEMPT=        # 逗号分隔：不受 PerToolCallLimiter 约束的 tool 名
# BUTLER_TOOL_NAMES=                    # 逗号分隔：自定义已知 tool 名白名单（normalize 用）
# BUTLER_TOOL_MASK_MIN_PRUNABLE=30000   # tool 输出掩码：可脱敏最小字符
# BUTLER_TOOL_RESULT_CACHE_TTL=120      # 工具结果缓存 TTL（秒）
# --- 工具层：Hashline 锚定（read/patch） ---
# BUTLER_HASHLINE_READ=                 # 1=read_file 返回 hashline 锚点
# BUTLER_HASHLINE_PATCH=1               # 1=patch 工具支持 hashline 定位
# --- 工具层：内联压缩（inline tool compress） ---
# BUTLER_INLINE_TOOL_COMPRESS_MAX_CHARS=1200  # 单 tool 输出超过此值触发内联压缩
# BUTLER_INLINE_TOOL_COMPRESS_KEEP=6          # 压缩后保留最近 N 行
# --- 工具层：终端 / 注册表安全 ---
# BUTLER_TERMINAL_PATTERN_APPROVE_TTL=86400   # /批准一次 pattern 有效期（秒）
# BUTLER_REGISTRY_ALLOWED_HOSTS=              # 逗号分隔：registry 拉取白名单 host
# --- 记忆层：容量上限（markdown chunks / context blocks） ---
# BUTLER_MEMORY_MAX_LINES=200          # 单 chunk 最大行数
# BUTLER_MEMORY_MAX_BYTES=25600        # 单 chunk 最大字节数
# --- 模式分类与指令召回 ---
# BUTLER_MODE_CLASSIFIER_MIN_CHARS=36   # 触发 mode classifier 的最小 query 字符数
# BUTLER_INTENT_KEYWORDS=               # 逗号分隔：自定义 intent 关键词（追加默认）
# BUTLER_INTENT_KEYWORDS_OFF=           # 1=关闭 intent 关键词
# BUTLER_INSTRUCTION_WALKUP_MAX_FILES=8 # /指令召回单次回放最多文件数
# --- 网关：渐进流 / 输入提示 / 队列 ---
# BUTLER_GATEWAY_PROGRESSIVE_MIN_CHARS=240   # 渐进推送触发字符阈值
# BUTLER_GATEWAY_PROGRESSIVE_INTERVAL=45     # 渐进推送最小间隔（秒）
# BUTLER_GATEWAY_PROGRESS_MAX_ACK_MESSAGES=1 # 单次进度确认最多消息数
# BUTLER_GATEWAY_TYPING_REFRESH_SECONDS=4    # 输入提示刷新间隔
# BUTLER_GATEWAY_TYPING_FETCH_TIMEOUT_SECONDS=2  # 输入提示拉取超时
# BUTLER_GATEWAY_QUEUE_DRAIN_FOLLOWUP=1      # drain 队列中 followup 消息的并发上限
# BUTLER_GATEWAY_DELEGATE_PUSH_ALWAYS=0      # 1=委派任务每次完成都推微信
# --- 出站 PII ---
# BUTLER_OUTBOUND_PII_SCRUB_EMAIL=1     # 1=同时脱敏邮箱（默认 1，0 关闭）
# --- 规则引擎 / Todo / Post-session / Turn budget ---
# BUTLER_RULES_ENGINE=1                 # 1=启用规则引擎
# BUTLER_RULES_MAX_CHARS=6000           # 规则引擎单次输出最大字符
# BUTLER_TODO_CONTINUATION=1            # 1=允许 todo 持续推进
# BUTLER_TODO_CONTINUATION_MAX=2        # todo 单轮最大续推次数
# BUTLER_TODO_STAGNATION_MAX=2          # todo 停滞容忍次数
# BUTLER_POST_SESSION_BUFFER_MESSAGES=8 # post-session 缓冲消息条数
# BUTLER_TURN_BUDGET_MIN_ITERATIONS=30  # 单轮 tool 调用的最小迭代数
# --- 微信限流 / CLI 体验 / Catalog 完整性 ---
# BUTLER_WECHAT_RATE_LIMIT_BACKOFF_MAX=  # 微信限流退避上限（秒）
# BUTLER_CLI_SHOW_REASONING=             # 1=CLI 显示 reasoning
# BUTLER_CATALOG_INTEGRITY_FAIL_CLOSED=1 # 1=catalog 校验失败时拒绝加载
# --- 额外工具（项目维度扩展） ---
# BUTLER_EXTRA_TOOLS=                    # 逗号分隔：项目维度默认启用的额外工具
# --- Transcript 检索 ---
# BUTLER_TRANSCRIPT_SEARCH_MAX_HITS=15   # transcript 搜索单次最多命中
# BUTLER_TRANSCRIPT_SEARCH_MAX_SESSIONS=5 # transcript 搜索最多扫描的会话数
# --- L4 开发引擎（butler/dev_engine/） ---
# BUTLER_DEV_ENGINE=1                    # 1=启用开发引擎增强（默认 1）
# BUTLER_DEV_AUTO_VERIFY=1              # 1=编辑后自动验证（默认 1）
# BUTLER_DEV_VERIFY_TIMEOUT=300         # 验证命令超时秒数（默认 300）
# BUTLER_DEV_MAX_FIX_ROUNDS=3           # 修复循环上限 K_max（默认 3）
# BUTLER_DEV_ROLLBACK_ENABLED=1         # 1=启用编辑回滚（默认 1）
# BUTLER_DEV_DIAGNOSTICS_INJECT=1       # 1=诊断自动注入上下文（默认 1）
# BUTLER_CODING_STRICT=0                # 1=严格模式：双重验证门（定理+测试）全 pass 方输出（CA4）
# BUTLER_GENTC_MUTATION_MIN_SCORE=0.6   # P-CT4a：GenTC 变异测试得分下限
# BUTLER_EXPERIENCE_MINING=1
# BUTLER_EXPERIENCE_MINING_AUTO_INGEST=0
# BUTLER_EXPERIENCE_MINING_MIN_CONFIDENCE=0.7
# BUTLER_EXPERIENCE_MINING_DAYS=7

