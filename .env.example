# Butler System 环境变量配置

# === 必填: 至少配置一个 LLM Provider ===

# Anthropic Claude (推荐作为默认)
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

# DeepSeek（可选；未配置时全栈默认仍走 MiniMax）
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat

# 默认 Provider（管家主对话、auxiliary 侧任务、无 step model 的工作流）
# BUTLER 代码默认 default_provider=minimax；也可在 ~/.butler/config.yaml 写 default_provider

# 通义千问 (Qwen)
# DASHSCOPE_API_KEY=sk-xxx

# 智谱 GLM
# ZHIPUAI_API_KEY=xxx

# Moonshot (Kimi)
# MOONSHOT_API_KEY=sk-xxx

# === Butler 原生微信网关（iLink Bot API）===
# WECHAT_TOKEN=
# WECHAT_ACCOUNT_ID=
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# 绑定: butler wechat-setup
# 常驻: bash scripts/install-butler-gateway-service.sh
#
# --- 生产网关强烈建议（P0）---
# WECHAT_DM_POLICY=allowlist
# WECHAT_ALLOWED_USERS=<你的微信 user id，逗号分隔>
# BUTLER_OWNER_WECHAT_ID=<Owner 微信 chat_id；runtime 推送目标，默认同 WECHAT_ALLOWED_USERS 首项>
# BUTLER_RUNTIME_ENABLED=1          # 0=禁用 runtime run/due
# BUTLER_RUNTIME_PUSH=1             # 0=任务结果不推微信
# BUTLER_DEFAULT_PROJECT=灵文1号
# BUTLER_TOOL_SAFE_ROOT=/home/you/projects/WFXM/projects
# BUTLER_GATEWAY_HANDLER_TIMEOUT=600
# BUTLER_GATEWAY_HANDLER_WORKERS=2
# BUTLER_SYNC_CONVERSATION_MEMORY=0   # 0=不把每轮聊天写入 experience；1=恢复旧行为
# BUTLER_EXPERIENCE_PRUNE_DAYS=30     # 清理超过 N 天的 conversation 回声；0=关闭
# BUTLER_PREFETCH_MAX_CHARS=3000      # 单轮 user 消息外包记忆块上限
# BUTLER_PREFETCH_TOTAL_MAX_CHARS=3500
# BUTLER_PREFETCH_PROJECT_MAX_CHARS=1200
# BUTLER_PREFETCH_FACTS_MAX_CHARS=400
# BUTLER_PREFETCH_EXPERIENCE_HITS=5
# BUTLER_PREFETCH_PROJECT_HITS=5    # 有 query 时项目 MEMORY 向量预取条数
# BUTLER_QUEUE_PREFETCH=1           # 试点推荐 1：上轮结束后 warm（下轮同句可命中缓存）
# BUTLER_PREFETCH_CACHE_TTL=90
# BUTLER_SEMANTIC_MEMORY=1          # 试点推荐 1：本地向量+混合检索（默认 hashing，无需外网）
# BUTLER_EMBEDDING_PROVIDER=local   # local | openai | minimax（API 需对应 *_API_KEY，失败回退 hashing）
# BUTLER_EMBEDDING_MODEL=hashing-v1 # openai 默认 text-embedding-3-small；minimax 默认 embo-01
# BUTLER_VECTOR_HYBRID_WEIGHT=0.5
# BUTLER_SEMANTIC_SEARCH_LIMIT=8
# BUTLER_MEMORY_HALF_LIFE_DAYS=30   # 检索衰减半衰期（天），越久记忆权重越低
# BUTLER_MEMORY_ACCESS_BOOST=0.12   # 访问次数对排序的 log 加权系数
# BUTLER_ENABLE_TERMINAL=1
# BUTLER_TERMINAL_ALLOWLIST_EXTRA=python3,bash   # 灵文1号 novel-factory 脚本（试点）

# === 真实 API Smoke（本地手动，默认 pytest 不运行） ===
# BUTLER_RUN_REAL_API_SMOKE=1
# BUTLER_SMOKE_DEEPSEEK_MODEL=deepseek-chat
# BUTLER_SMOKE_DEEPSEEK_REASONER_MODEL=deepseek-reasoner
# BUTLER_SMOKE_MINIMAX_MODEL=MiniMax-M2.7
# BUTLER_SMOKE_QWEN_MODEL=qwen-max
# 运行: pytest -m live_llm tests/test_real_api_smoke.py

# === 管家配置 ===

# BUTLER_HOME=~/.butler
# BUTLER_PROJECTS_DIR=./projects

# === 工具安全边界 ===
# 默认工具访问范围为当前项目 workspace；未选择项目时回退到 BUTLER_TOOL_SAFE_ROOT 或进程 cwd。
# 建议生产网关显式设置安全根目录。
# BUTLER_TOOL_SAFE_ROOT=/path/to/workspace
#
# terminal 工具默认关闭。仅在明确接受本机命令执行风险时启用；
# 启用后仍使用受限 argv + allowlist 模式，不支持 shell 管道/重定向/变量展开。
# read_file 限制单文件 1MiB / 单次 1000 行；terminal 限制单次 120 秒 / 50000 字符输出。
# write_file / patch 使用同目录临时文件原子替换，并拒绝 symlink / hardlink / 非普通文件目标。
# 工具错误、guardrail block/halt、dispatcher 兜底会追加 ok/tool/code 兼容 envelope，
# 并在内存中保留脱敏审计事件供 /health 汇总。
# guardrail halt 使用 TOOL_GUARDRAIL_HALT，block 使用 TOOL_GUARDRAIL_BLOCKED。
# 自定义 dispatcher 若手写完整 envelope，应直接复用 finalize_tool_result 以写入审计。
# BUTLER_ENABLE_TERMINAL=0

# === Gateway 会话生命周期 ===
# 按 session_key 缓存 AgentLoop；超过空闲 TTL 或 LRU 上限时会触发 session finalize。
# BUTLER_GATEWAY_SESSION_IDLE_TTL_SECONDS=3600
# BUTLER_GATEWAY_MAX_SESSIONS=128
# Session reset/evict/LRU also clears in-memory tool audit events for that session_key.

# === WeChat 配置 (Phase 3) ===

# 入站图片/语音理解（网关层，不走厂长主模型）
# BUTLER_WECHAT_INBOUND_MEDIA=1
# BUTLER_WECHAT_MEDIA_MAX_CHARS=3000
# 识图：MiniMax Coding Plan VLM（需 MINIMAX_API_KEY；国际区默认 https://api.minimax.io）
# BUTLER_WECHAT_MINIMAX_API_HOST=https://api.minimax.io
# BUTLER_WECHAT_VISION_TIMEOUT=45
# 语音：优先 iLink 自带转写；无转写时对 .silk 用 ffmpeg + 本地 faster-whisper（MiniMax 无公开 STT）
# BUTLER_WECHAT_STT_PROVIDER=local
# BUTLER_WECHAT_WHISPER_MODEL=small
# BUTLER_WECHAT_STT_PROVIDER=off

# Wechaty
# WECHATY_PUPPET=wechaty-puppet-service
# WECHATY_PUPPET_SERVICE_TOKEN=xxx
